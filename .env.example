# Copy this to .env and fill in your values
# Railway will inject DATABASE_URL automatically — only needed for local dev

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aeris
MAGIC_LINK_SECRET=dev-secret-replace-with-64-random-chars-in-production
ADMIN_PASSWORD=changeme
PORTAL_BASE_URL=http://localhost:8000

# SendGrid (leave blank to skip emails during local dev)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@aeristechnicalsolutions.com

# SharePoint (leave blank to skip SP uploads during prototype)
SP_SITE_URL=https://aeristechnicalsolutions.sharepoint.com/sites/TimeTracking
SP_CLIENT_ID=
SP_CLIENT_SECRET=

UPLOAD_DIR=uploads
